<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_bot">



<material name="white">
    <color rgba="1 1 1 1"/>
</material>

<material name="orange">
    <color rgba="1 0.3 0.1 1"/>
</material>

<material name="blue">
    <color rgba="0.2 0.2 1 1"/>
</material>

<material name="black">
    <color rgba="0 0 0 1"/>
</material>



<!--base link-->
<link name="base_link">
    
</link>


<joint name="chassis_joint" type="fixed">
   <parent link="base_link"/>
   <child link="chassis_link"/>
   <origin xyz="-0.1 0.0 0.0"/> 
</joint>


<!--chassis link-->

<link name="chassis_link">
    <visual>
        <origin xyz="0.15 0.0 0.075"/>
        <geometry>
            <box size="0.3 0.3 0.15"/>
        </geometry>
    </visual>

    <material name="white">
            
    </material>

    <collision>

        <origin xyz="0.15 0.0 0.075"/>
        <geometry>
            <box size="0.3 0.3 0.15"/>
        </geometry>

    </collision>
   
   <inertial>
      <!-- 惯性原点与几何中心对齐 -->
      <origin xyz="0.15 0.0 0.075" rpy="0 0 0"/>
      <mass value="1.0"/>
      <!-- 立方体惯性张量公式：Ixx = m*(y²+z²)/12 -->
      <inertia 
        ixx="0.009375" ixy="0" ixz="0"
        iyy="0.009375" iyz="0"
        izz="0.015"/>
    </inertial>  
        
    
</link>

<!--left wheel link-->
<joint name="left_wheel_joint" type="continuous">
  <parent link="base_link"/>
  <child link="left_link"/>
  <origin xyz="0.0 0.175 0.0" rpy="-1.57 0.0 0.0"/>
  <axis xyz="0.0 0.0 1"/>
</joint>

<link name="left_link">
    <visual>
    
        <geometry>
            <cylinder radius="0.05" length="0.04"/> 
        </geometry>
        <material name="blue">
            
        </material>
            
        
    </visual>
    <collision>
        <geometry>
            <cylinder radius="0.05" length="0.04"/> 
        </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <!-- 圆柱惯性张量：绕轴（izz）和垂直轴（ixx/iyy）不同 -->
      <inertia 
        ixx="0.0000233" ixy="0" ixz="0"
        iyy="0.0000233" iyz="0"
        izz="0.0000125"/>
    </inertial>



</link>

<!--right wheel link-->
<joint name="right_wheel_joint" type="continuous">
  <parent link="base_link"/>
  <child link="right_link"/>
  <origin xyz="0.0 -0.175 0.0" rpy="1.57 0.0 0.0"/>
  <axis xyz="0.0 0.0 -1"/>
</joint>

<link name="right_link">
    <visual>
    
        <geometry>
            <cylinder radius="0.05" length="0.04"/> 
        </geometry>
        <material name="blue">
            
        </material>
            
        
    </visual>
    <collision>
        <geometry>
            <cylinder radius="0.05" length="0.04"/> 
        </geometry>
    
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia 
        ixx="0.0000233" ixy="0" ixz="0"
        iyy="0.0000233" iyz="0"
        izz="0.0000125"/>
    </inertial>

</link>


<!--caster wheel link-->
<joint name="caster_joint" type="fixed">
    <parent link="chassis_link"/>
    <child link="caster_link"/>
    <origin xyz="0.24 0.0 0.0"/>
    
</joint>

<link name="caster_link">
 <visual>
    <geometry>
        
        <sphere radius="0.05"/>
            
    </geometry>

    <material name="black">
        
    </material>
 </visual>



 <collision>
     <geometry>
        
        <sphere radius="0.05"/>
        
     </geometry>
 </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <!-- 球体惯性张量：所有轴相同 -->
      <inertia 
        ixx="0.00001" ixy="0" ixz="0"
        iyy="0.00001" iyz="0"
        izz="0.00001"/>
    </inertial>
    
</link>


   

</robot>